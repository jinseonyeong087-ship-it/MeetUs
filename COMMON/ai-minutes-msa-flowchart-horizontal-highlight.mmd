%% =======================
%% TRAFFIC FLOW
%% =======================

USER --> IGW
IGW --> ALB
ALB --> LISTENER
LISTENER --> TG_BLUE
LISTENER -. switch .-> TG_GREEN
TG_BLUE --> FE_BLUE
TG_BLUE --> CORE_BLUE
TG_GREEN --> FE_GREEN
TG_GREEN --> CORE_GREEN

FE_BLUE --> CORE_BLUE
FE_GREEN --> CORE_GREEN

CORE_BLUE --> RDS
CORE_BLUE --> S3
CORE_BLUE --> AI
CORE_GREEN --> RDS
CORE_GREEN --> S3
CORE_GREEN --> AI

AI --> TRANS
AI --> BEDROCK
AI --> RDS
AI --> S3

%% =======================
%% CI/CD FLOW
%% =======================

GHA --> ECR
ECR --> CD
CD --> FE_GREEN
CD --> CORE_GREEN
ECR --> AI

%% =======================
%% OUTBOUND INTERNET
%% =======================

AI --> NAT
NAT --> BEDROCK
